{
  "name": "mosaic-platform",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@mosaic/platform",
    "dev:all": "turbo dev",
    "dev:budget": "turbo dev --filter=@mosaic/budget",
    "dev:calendar": "turbo dev --filter=@mosaic/calendar",
    "dev:baby-tracker": "turbo dev --filter=@mosaic/baby-tracker",
    "dev:home": "turbo dev --filter=@mosaic/home",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "convex": "^1.17.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
