# apps/calendar — Production Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
#
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables

# Convex — get from Convex Dashboard → calendar project → Settings → URL & Deploy Key
NEXT_PUBLIC_CONVEX_URL=

# Clerk — same instance as all other Mosaic apps
# Use pk_test_ / sk_test_ for local dev and Vercel preview deployments
# Use pk_live_ / sk_live_ for Vercel production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk sign-in routes — always point to the platform
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://atlas-homevault.com/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://atlas-homevault.com/sign-up

# Cross-app links
NEXT_PUBLIC_PLATFORM_URL=https://atlas-homevault.com

# Corepack — set in Vercel Dashboard, not .env.local
# ENABLE_EXPERIMENTAL_COREPACK=1
